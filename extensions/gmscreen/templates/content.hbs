  <div id="regles" class="tab active" data-group="sheet" data-tab="regles">
    <div class="menucol">
      <ul>
        <li><a data-action="menulink" data-target="regle1">Question de bon sens</a></li>
        <li><a data-action="menulink" data-target="regle2">Actions</a></li>
